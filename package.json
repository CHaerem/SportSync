{
  "name": "zenji",
  "version": "2.0.0",
  "description": "Zenji - a calm personal sports dashboard where scheduled Claude agents (research, verify, editorial, and self-maintenance loops) find, verify, and editorialize the events static APIs miss; static pipeline + GitHub Pages, zero infrastructure",
  "main": "docs/index.html",
  "scripts": {
    "dev": "python3 -m http.server 8000 --directory docs",
    "build": "npm run update:data && npm run build:events && npm run build:calendar",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:data": "npm run validate:data",
    "update:data": "node scripts/fetch/index.js",
    "build:events": "node scripts/build-events.js",
    "build:calendar": "node scripts/build-ics.js",
    "validate:data": "node scripts/validate-events.js",
    "fetch:results": "node scripts/fetch-results.js",
    "screenshot": "node scripts/screenshot.js",
    "clean": "rm -rf docs/data/*.json docs/data/*.ics",
    "refresh": "npm run clean && npm run build"
  },
  "keywords": [
    "sports",
    "dashboard",
    "static-site",
    "github-pages",
    "api",
    "football",
    "golf",
    "tennis",
    "formula-1",
    "chess",
    "esports"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "playwright": "^1.50.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CHaerem/zenji.git"
  },
  "homepage": "https://zenji.app/",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
