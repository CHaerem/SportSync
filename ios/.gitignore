# ios/ — scoped to this directory only. Do NOT touch the repo-root .gitignore
# (owned by the datapipeline docs/data/ whitelist — see CLAUDE.md).

# Generated by `xcodegen generate` from project.yml — never check in the project file.
*.xcodeproj/
*.xcworkspace/

# Xcode user state / caches
xcuserdata/
DerivedData/
.build/
.swiftpm/
*.hmap
*.ipa
*.dSYM
*.dSYM.zip
.DS_Store
